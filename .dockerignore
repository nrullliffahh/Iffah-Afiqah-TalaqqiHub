# Version control and IDE
.git
.gitignore
.cursor
.classpath
.project
.worktrees
**/.worktrees

# Secrets (set in Kerocket Deploy tab)
.env
.env.*
!.env.example

# Documentation and notes
*.md
!README.md
*.txt
sources.txt
agent-tools
**/agent-transcripts

# Local scripts and Windows helpers
*.bat
*.ps1
scripts

# Database dumps and migrations (not needed at runtime)
*.sql
db

# Build output and local tooling
target
bin
build
node_modules
tools
package-lock.json

# Compiled classes and local libs (Maven WAR rebuilds these)
WEB-INF/classes
WEB-INF/lib

# User uploads (mount or persist separately in production)
uploads
!uploads/.gitkeep

# Local test/debug pages
test_*.jsp
test_*.html
tmp_*.html
tmp_*.txt
debug-*.jsp
beautiful_page.html
*_backup*
*.html

# Kerocket/Nixpacks config is not needed inside the image
kerocket.toml
nixpacks.toml
