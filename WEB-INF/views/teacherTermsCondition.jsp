    <script>
        document.getElementById('closeBtnTop').addEventListener('click', function(){ window.history.back(); });
        document.getElementById('cancelBtn').addEventListener('click', function(){ window.history.back(); });
        document.getElementById('agreeBtn').addEventListener('click', function(){
            // Notify opener (registration page) that terms were accepted, then close popup.
            try {
                if (window.opener && !window.opener.closed) {
                    window.opener.postMessage({ type: 'teacherTermsAccepted', timestamp: Date.now() }, '*');
                }
            } catch (e) {
                console.warn('Unable to postMessage to opener', e);
            }
            alert('Thank you. You have agreed to the Terms & Conditions.');
            // If opened as a popup, close; otherwise navigate back
            if (window.opener && !window.opener.closed) {
                window.close();
            } else {
                window.history.back();
            }
        });
    </script>
