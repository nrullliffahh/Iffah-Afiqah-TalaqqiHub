# =============================================================================
# Kerocket Deploy tab — copy these into Project → Settings → Environment variables
# =============================================================================
# DB_USER and DB_PASSWORD are REQUIRED (Kerocket validates against this file).
# Do not commit a real .env file with secrets.

PORT=8080

# Aiven / external MySQL (recommended)
DB_URL=jdbc:mysql://YOUR_HOST:16135/talaqqihub_db?sslMode=REQUIRED&serverTimezone=UTC
DB_USER=avnadmin
DB_PASSWORD=REPLACE_WITH_AIVEN_PASSWORD

# Optional: Kerocket attached MySQL data service (alternative to DB_USER/DB_PASSWORD)
DATABASE_URL=

GEMINI_API_KEY=

# If Kerocket does not pass DB_USER/DB_PASSWORD separately, embed credentials in DB_URL:
# DB_URL=jdbc:mysql://avnadmin:YOUR_PASSWORD@YOUR_HOST:16135/talaqqihub_db?sslMode=REQUIRED

# 8x8 JaaS (production video) — from https://jaas.8x8.vc/ → API Keys
# JITSI_PROVIDER=jaas
# JITSI_APP_ID=vpaas-magic-cookie-...
# JITSI_API_KEY=your-api-key-id
# JITSI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
