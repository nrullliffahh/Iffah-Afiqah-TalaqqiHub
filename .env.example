# =============================================================================
# Kerocket Deploy tab — copy into Project → Settings → Environment variables
# =============================================================================
# Kerocket validates keys listed here (uncommented). Do not commit a real .env.

PORT=8080

# Recommended for Aiven: embed user + password in DB_URL (no separate DB_USER/DB_PASSWORD needed)
DB_URL=jdbc:mysql://avnadmin:REPLACE_WITH_AIVEN_PASSWORD@YOUR_HOST.aivencloud.com:16135/talaqqihub_db?sslMode=REQUIRED&serverTimezone=UTC

# Alternative: separate credentials (uncomment these AND use DB_URL without user:pass@ in the URL)
# DB_URL=jdbc:mysql://YOUR_HOST.aivencloud.com:16135/talaqqihub_db?sslMode=REQUIRED&serverTimezone=UTC
# DB_USER=avnadmin
# DB_PASSWORD=REPLACE_WITH_AIVEN_PASSWORD

# Optional: only if you attach Kerocket MySQL data service (not needed for external Aiven)
# DATABASE_URL=

GEMINI_API_KEY=

# 8x8 JaaS (production video) — from https://jaas.8x8.vc/ → API Keys
# JITSI_PROVIDER=jaas
# JITSI_APP_ID=vpaas-magic-cookie-...
# JITSI_API_KEY=your-api-key-id
# JITSI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
